{
  "name": "performer-catalog",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "collect:data": "node scripts/collect-performers.mjs",
    "index:aliases": "node scripts/update-performer-index-aliases.mjs",
    "debug:iafd": "node scripts/debug-iafd-page.mjs",
    "start:proxy": "node scripts/playwright-proxy/server.mjs",
    "start:dev": "concurrently -k \"npm run start:proxy\" \"npm start\"",
    "proxy:check": "node scripts/playwright-proxy/check-proxy.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "playwright": "^1.60.0",
    "concurrently": "^8.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
